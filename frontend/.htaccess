# BAM — Apache serves the static frontend directly, Passenger handles
# /api/* and the templated root HTML (for social-share OG tags).

RewriteEngine On

# Always route API calls to the Python app.
RewriteRule ^api/ - [PT,L]

# Route the root URL through Passenger so share links (?s=...&n=...&t=...)
# get server-side templated OG meta tags.
RewriteRule ^$ - [PT,L]

# For everything else: if the file exists on disk, Apache serves it;
# otherwise fall through to Passenger (SPA fallback in app.py).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . - [PT,L]

# Cache static assets aggressively. index.html stays fresh so OG tag
# updates and new JS bundles aren't stuck behind CDN/browser caches.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                 "access plus 0 seconds"
    ExpiresByType text/css                  "access plus 7 days"
    ExpiresByType application/javascript    "access plus 7 days"
    ExpiresByType image/png                 "access plus 30 days"
    ExpiresByType image/avif                "access plus 30 days"
    ExpiresByType image/webp                "access plus 30 days"
    ExpiresByType image/svg+xml             "access plus 30 days"
    ExpiresByType font/woff2                "access plus 30 days"
</IfModule>

# Compress text responses.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
